# =============================================================================
# CASH MAKER — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env.local e preencha com seus valores reais.
# NUNCA commite o .env.local no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# BANCO DE DADOS
# PostgreSQL via Neon.tech (https://neon.tech)
# Formato: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://cashmaker:cashmaker123@localhost:5432/cashmaker_dev"

# -----------------------------------------------------------------------------
# AUTENTICAÇÃO — NextAuth.js v5
# NEXTAUTH_SECRET: string aleatória e segura (mínimo 32 caracteres)
# Gere com: openssl rand -base64 32
# NEXTAUTH_URL: URL base da aplicação
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# E-MAIL TRANSACIONAL — Resend (https://resend.com)
# Usado para: alertas de saldo negativo, gastos elevados, recuperação de senha
# Disponível a partir da v1.0 (fora do MVP)
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@cashmaker.app"

# -----------------------------------------------------------------------------
# CRON JOB — Gastos Fixos
# Protege a rota /api/cron/fixed-expenses contra execução não autorizada.
# Gere com: openssl rand -base64 32
# Configure também no painel da Vercel em Settings > Environment Variables.
# -----------------------------------------------------------------------------
CRON_SECRET=""

# -----------------------------------------------------------------------------
# AMBIENTE
# "development" | "production" | "test"
# -----------------------------------------------------------------------------
NODE_ENV="development"
